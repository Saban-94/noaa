rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'hsaban2025@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidOrder(data) {
      return data.keys().hasAll(['date', 'time', 'customerName', 'destination', 'items', 'status', 'createdAt', 'updatedAt', 'createdBy'])
        && data.date is string && data.date.size() == 10
        && data.time is string && data.time.size() <= 5
        && data.customerName is string && data.customerName.size() <= 200
        && data.destination is string && data.destination.size() <= 500
        && data.items is string && data.items.size() <= 2000
        && data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.createdBy == request.auth.uid;
    }

    function isValidDriver(data) {
      return data.keys().hasAll(['name', 'phone', 'vehicleType', 'status', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.vehicleType in ['truck', 'crane']
        && data.status in ['active', 'off_duty']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['customerNumber', 'name', 'phoneNumber', 'createdAt', 'updatedAt'])
        && data.customerNumber is string && data.customerNumber.size() <= 50
        && data.name is string && data.name.size() <= 200
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['title', 'dueDate', 'dueTime', 'isCompleted', 'userId', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.dueDate is string && data.dueDate.size() == 10
        && data.dueTime is string && data.dueTime.size() <= 5
        && data.isCompleted is bool
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp', 'visibility', 'type'])
        && data.text is string && data.text.size() <= 4000
        && data.senderId == request.auth.uid
        && data.visibility in ['everyone', 'managers']
        && data.type in ['text', 'image', 'file', 'video', 'system']
        && data.timestamp is timestamp
        // Optional fields for file/image/video
        && (!('fileUrl' in data) || data.fileUrl is string)
        && (!('fileName' in data) || data.fileName is string)
        && (!('fileType' in data) || data.fileType is string)
        && (!('metadata' in data) || data.metadata is map)
        && (!('readBy' in data) || data.readBy is list);
    }

    function isValidTransfer(data) {
      return data.keys().hasAll(['sourceBranch', 'destinationBranch', 'items', 'status', 'requestedBy', 'requestedByName', 'createdAt', 'updatedAt'])
        && data.sourceBranch in ['החרש', 'התלמיד']
        && data.destinationBranch in ['החרש', 'התלמיד']
        && data.items is string && data.items.size() <= 2000
        && data.status in ['pending', 'approved', 'on_way', 'delivered', 'cancelled']
        && data.requestedBy == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // --- Collection Rules ---

    match /orders/{orderId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && isValidOrder(incoming()) 
                     && incoming().createdAt == request.time 
                     && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isValidOrder(incoming())
                     && incoming().updatedAt == request.time
                     && (incoming().createdAt == existing().createdAt || !('createdAt' in existing()))
                     && (incoming().createdBy == existing().createdBy || !('createdBy' in existing()))
                     && (
                       isAdmin() || 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'eta', 'orderFormId', 'deliveryNoteId', 'updatedAt', 'items', 'destination', 'time', 'date', 'driverId', 'warehouse', 'orderNumber', 'source'])
                     );
      allow delete: if isAdmin();
    }

    match /drivers/{driverId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && isValidDriver(incoming())
                     && incoming().createdAt == request.time
                     && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isValidDriver(incoming())
                     && incoming().updatedAt == request.time
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && isValidCustomer(incoming())
                     && incoming().createdAt == request.time
                     && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isValidCustomer(incoming())
                     && incoming().updatedAt == request.time
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read: if isEmailVerified() && resource.data.userId == request.auth.uid;
      allow create: if isEmailVerified() && isValidReminder(incoming())
                     && incoming().createdAt == request.time
                     && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && existing().userId == request.auth.uid 
                     && isValidReminder(incoming())
                     && incoming().updatedAt == request.time
                     && incoming().createdAt == existing().createdAt
                     && incoming().userId == existing().userId;
      allow delete: if isEmailVerified() && existing().userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isEmailVerified() && (
        resource.data.visibility == 'everyone' || 
        isAdmin() || 
        request.auth.token.email == 'itzik@saban.co.il'
      );
      allow create: if isEmailVerified() && isValidMessage(incoming())
                     && incoming().timestamp == request.time;
      allow update: if isEmailVerified() && (
        // Allow marking as read: only the readBy field can be changed
        incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) &&
        // Current user must be adding themselves to the list
        request.auth.uid in incoming().readBy &&
        // Existing data must be preserved (mostly)
        incoming().text == existing().text &&
        incoming().senderId == existing().senderId
      );
      allow delete: if isAdmin() || (isEmailVerified() && resource.data.senderId == request.auth.uid);
    }

    match /transfers/{transferId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && isValidTransfer(incoming())
                     && incoming().createdAt == request.time
                     && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'eta', 'updatedAt', 'assignedDriverId'])
      );
      allow delete: if isAdmin();
    }
  }
}
